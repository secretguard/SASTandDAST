# ─────────────────────────────────────────────────────────────────────────────
# SASTandDAST Lab — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Nessus ────────────────────────────────────────────────────────────────────
# Get a free activation code at: https://www.tenable.com/products/nessus/nessus-essentials
# Leave blank to complete activation via the browser after first start.
NESSUS_ACTIVATION_CODE=
NESSUS_USERNAME=admin
NESSUS_PASSWORD=admin123

# ── ZAP ───────────────────────────────────────────────────────────────────────
ZAP_API_KEY=lab-api-key-2024

# ── Ports (change if defaults conflict with existing services) ─────────────────
SONARQUBE_PORT=9000
ZAP_PORT=8090
NESSUS_PORT=8834
DVWA_PORT=8888
VULNSHOP_PORT=4040
