APP_NAME=VulnShop
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:4040

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=vulnshop-db
DB_PORT=3306
DB_DATABASE=vulnshop
DB_USERNAME=vulnshop_user
DB_PASSWORD=vulnshop_pass

# VULNERABILITY: Hardcoded admin credentials committed to version control (CWE-798)
ADMIN_EMAIL=admin@vulnshop.local
ADMIN_PASSWORD=admin123

SESSION_DRIVER=file
SESSION_LIFETIME=120
